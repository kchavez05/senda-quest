rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - The user's unique ID
    //   - name: string (required) - Character name
    //   - class: string (required) - Character class
    //   - race: string (required) - Character race
    //   - background: string (optional) - Character background
    //   - hp: number (required) - Current health
    //   - maxHp: number (required) - Max health
    //   - mana: number (required) - Current mana
    //   - maxMana: number (required) - Max mana
    //   - inventory: list (optional) - List of items
    //   - combatCount: number (optional) - Number of combat encounters
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // Collection: /users/{userId}/logs/{logId}
    // Document ID: unique log ID
    // Fields:
    //   - id: string (required) - Unique log ID
    //   - sender: string (required) - gm, player, or system
    //   - text: string (required) - The message text
    //   - timestamp: number (required) - Timestamp of the log
    //   - uid: string (required) - The owner's UID
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'class', 'race', 'hp', 'maxHp', 'mana', 'maxMana']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.class is string &&
             data.race is string &&
             data.hp is number &&
             data.maxHp is number &&
             data.mana is number &&
             data.maxMana is number;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['id', 'sender', 'text', 'timestamp', 'uid']) &&
             data.id is string &&
             data.sender in ['gm', 'player', 'system'] &&
             data.text is string && data.text.size() > 0 && data.text.size() < 10000 &&
             data.timestamp is number &&
             data.uid is string && data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /games/{gameId} {
        allow read, write: if isOwner(userId);

        match /logs/{logId} {
          allow read: if isOwner(userId);
          allow create: if isOwner(userId) && isValidLog(request.resource.data);
          allow update: if isOwner(userId) && isValidLog(request.resource.data);
          allow delete: if isOwner(userId);
        }
      }
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
